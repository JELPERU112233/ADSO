<script>
const DATA={
  sw:   {t:'Switch 1GbE · 16 puertos',d:'Hub LAN. Dell Latitude y ThinkPad por cable. MacBook y Samsung Tab por WiFi.'},
  terra:{t:'TerraMaster F2-210',d:'Backup 3-2-1. ① SATA HDD 500GB ② SATA HDD 1TB. rsync nocturno desde TrueNAS.'},
  tnas: {t:'TrueNAS VM',d:'Pool ZFS IronWolf 8TB. Datasets: tank/general, tank/backups, tank/trabajo.'},
  sct:  {t:'LXC Syncthing — hub',d:'Ubuntu 22.04. Conflictos resueltos por timestamp. Escribe en /mnt/tank vía bind mount.'},
  plex: {t:'LXC Plex Media Server',d:'Quick Sync con iGPU UHD 630. Lee desde tank/general/PLEX SERVER.'},
  tsn:  {t:'LXC Tailscale',d:'Exit node VPN. Todos los dispositivos acceden como si estuvieran en LAN.'},
  ha:   {t:'LXC Home Assistant',d:'Zigbee, Tuya, Alexa. Automatización del hogar.'},
  stor: {t:'bind mount /mnt/tank',d:'Acceso directo al ZFS desde todos los LXC. Sin copias intermedias.'},
  dell: {t:'Dell Latitude 5431 · Windows',d:'Cable LAN. Syncthing + Tailscale en Windows 11.'},
  tp:   {t:'ThinkPad T14 Gen 4',d:'Equipo principal. Cable LAN. Syncthing + Tailscale. TrackPoint rojo característico.'},
  mac:  {t:'MacBook Air M1',d:'WiFi. Syncthing + Time Machine via SMB + Tailscale para acceso remoto.'},
  tab:  {t:'Samsung Galaxy Tab 10FE',d:'WiFi + Tailscale Android. FolderSync Pro sincroniza via SMB.'},
};
const box=document.getElementById('tip-box');
let hide;
function tip(e,k){
  clearTimeout(hide);
  const d=DATA[k]; if(!d) return;
  box.innerHTML='<strong style="font-size:12px;display:block;margin-bottom:3px">'+d.t+'</strong>'+d.d;
  const wrap=document.querySelector('.wrap').getBoundingClientRect();
  box.style.left=Math.min(e.clientX-wrap.left+10,wrap.width-240)+'px';
  box.style.top=(e.clientY-wrap.top+10)+'px';
  box.classList.add('show');
  hide=setTimeout(()=>box.classList.remove('show'),5000);
}
document.addEventListener('click',e=>{if(!e.target.closest('[onclick]'))box.classList.remove('show');});
const FLOWS={sync:['gr-sync','lk-sct-st'],plex:['gr-plex','lk-plex-st'],tail:['gr-tail'],bkp:['gr-bkp'],all:['gr-sync','gr-plex','gr-tail','gr-bkp','lk-sct-st','lk-plex-st']};
const ALL=['gr-sync','gr-plex','gr-tail','gr-bkp','lk-sct-st','lk-plex-st'];
function fl(mode){
  document.querySelectorAll('.btns button').forEach(b=>b.classList.remove('on'));
  document.getElementById('b-'+mode).classList.add('on');
  const show=FLOWS[mode]||ALL;
  ALL.forEach(id=>{const el=document.getElementById(id);if(el)el.style.opacity=show.includes(id)?'1':'0.05';});
}
</script>
