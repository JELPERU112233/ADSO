<head>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans);background:transparent;color:var(--color-text-primary)}
.wrap{position:relative;width:100%}
.tooltip{position:absolute;background:var(--color-background-primary);border:0.5px solid var(--color-border-secondary);border-radius:8px;padding:8px 12px;font-size:12px;color:var(--color-text-primary);max-width:230px;pointer-events:none;opacity:0;transition:opacity .18s;z-index:20;line-height:1.55}
.tooltip.show{opacity:1}
.legend{display:flex;flex-wrap:wrap;gap:6px 14px;padding:8px 14px;border:0.5px solid var(--color-border-tertiary);border-radius:8px;margin:10px 0 0;font-size:11px;color:var(--color-text-secondary)}
.leg{display:flex;align-items:center;gap:5px}
.dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.btns{display:flex;gap:7px;margin:10px 0 4px;flex-wrap:wrap}
button{font-size:11px;padding:4px 10px;border:0.5px solid var(--color-border-secondary);border-radius:6px;background:transparent;color:var(--color-text-primary);cursor:pointer}
button.on{background:var(--color-background-info);color:var(--color-text-info);border-color:var(--color-border-info)}
button:hover{background:var(--color-background-secondary)}
</style>
</head>
